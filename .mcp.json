{
  "mcpServers": {
    "PaddleOCR": {
      "command": "uvx",
      "args": ["--python", "3.12", "--from", "paddleocr-mcp", "paddleocr_mcp"],
      "env": {
        "PADDLEOCR_MCP_AISTUDIO_REQUEST_TIMEOUT": "600",
        "PADDLEOCR_MCP_AISTUDIO_POLL_TIMEOUT": "1200",
        "PADDLEOCR_MCP_HTTP_TIMEOUT": "1200"
      }
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=iumtsqkuppgopxskuwns"
    }
  }
}
