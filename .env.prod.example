# Copy this file to .env.prod for local reference, then install the values on
# the production host or hosting platform. Replace every placeholder. Do not
# commit the real production file.

NODE_ENV=production
HOST=0.0.0.0
PORT=3080
NODE_OPTIONS=--max-old-space-size=1536
CONFIG_PATH=/data/librechat.yaml
# Historical variable name used by the current production startup script.
RENDER_DATA_DIR=/data

LIBRECHAT_DOMAIN=chat.<your-domain>
DOMAIN_CLIENT=https://chat.<your-domain>
DOMAIN_SERVER=https://chat.<your-domain>

# Use production-only database resources. Prefer a separate MongoDB Atlas
# project/cluster and a separate Supabase project for production. Do not point
# production at development data.
MONGO_URI=mongodb+srv://<prod-user>:<prod-password>@<prod-cluster>/<prod-db>?retryWrites=true&w=majority&appName=<app-name>
STEEL_POSTGRES_URL=postgresql://<prod-user>.<project-ref>:<prod-password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require&uselibpqcompat=true

OPENAI_API_KEY=user_provided
OPENAI_MODELS=gpt-5.5
OPENAI_DEFAULT_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=medium
OPENAI_OAUTH_AUTH_FILE=/data/openai-oauth/auth.json

SEARCH=false
MEILI_HOST=
MEILI_MASTER_KEY=
MEILI_NO_SYNC=true

ALLOW_REGISTRATION=false
ALLOW_SOCIAL_LOGIN=false

JWT_SECRET=<generate-strong-secret>
JWT_REFRESH_SECRET=<generate-strong-secret>
CREDS_KEY=<generate-32-byte-base64>
CREDS_IV=<generate-16-byte-base64>

#========================#
# S3 AWS Bucket          #
#========================#

AWS_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-east-1
AWS_BUCKET_NAME=
S3_URL_EXPIRY_SECONDS=43200
# Optional single path segment for shared-bucket namespaces, e.g. prod.
S3_KEY_PREFIX=prod

# PaddleOCR-VL-1.6 through paddleocr-mcp AI Studio API.
PADDLEOCR_MCP_AISTUDIO_ACCESS_TOKEN=
PADDLEOCR_FORCE_REINSTALL=false
PADDLEOCR_UV_PYTHON_INSTALL_DIR=/data/paddleocr/python
